{
	"name" : "logicommerce/plugins",
	"homepage" : "https://www.logicommerce.com",
	"minimum-stability" : "stable",
	"type" : "project",
	"description" : "Plugins for Logicommerce Commerces",
	"keywords" : [
		"ecommerce",
		"plugins",
		"ComLogicommerceSprinque"
	],
	"autoload" : {
		"psr-4" : {
			"Plugins\\ComLogicommerceSprinque\\" : "src/"
		},
		"exclude-from-classmap": [ 
			"test/"
		]
	},
	"autoload-dev": {
        "psr-4": {
        	"Test\\" : "test/"
        }
    },
    "require" : {
		"php": "^8.2"
	},
	"require-dev" : {
		"phpunit/phpunit" : "^9.5",
		"phpunit/php-invoker" : "^3.1"
	},
	"extra": {
		"plugin-key": "sprinque"
	}
}