<div class="userPaymentCards userPaymentCardData">

    <div class="field identifier">
        {{ languageSheet[constant('Plugins\\ComLogicommercePaypalcommerceplatform\\Enums\\LanguageLabels::COM_LOGICOMMERCE_PAYPAL_PLATFORM_IDENTIFIED')] }}:
        {{ pluginPaymentToken.data.identifier }}
    </div>
    <div class="field cardNumber">
        {{ languageSheet[constant('Plugins\\ComLogicommercePaypalcommerceplatform\\Enums\\LanguageLabels::COM_LOGICOMMERCE_PAYPAL_PLATFORM_CARD_NUMBER')] }}:
        {{ pluginPaymentToken.data.cardNumber }}
    </div>
    <div class="field expiryDate">
        {{ languageSheet[constant('Plugins\\ComLogicommercePaypalcommerceplatform\\Enums\\LanguageLabels::COM_LOGICOMMERCE_PAYPAL_PLATFORM_EXPIRY_DATE')] }}:
        {% if pluginPaymentToken.data.expiryDate is not null %}
            {{ formatDateTime( pluginPaymentToken.data.expiryDate) }}
        {% endif %}
    </div>

</div>   